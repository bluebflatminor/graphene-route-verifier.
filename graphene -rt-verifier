<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Graphene Integration Route Verifier</title>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500;600&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #0a0e14;
      --panel: #111620;
      --panel2: #161c28;
      --border: #1e2a3a;
      --accent: #3b82f6;
      --accent2: #22d3ee;
      --gold: #f59e0b;
      --green: #10b981;
      --red: #ef4444;
      --orange: #f97316;
      --text: #e2e8f0;
      --text2: #94a3b8;
      --text3: #475569;
      --mono: 'IBM Plex Mono', monospace;
      --sans: 'IBM Plex Sans', sans-serif;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--sans);
      min-height: 100vh;
      overflow-x: hidden;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(59,130,246,0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(59,130,246,0.03) 1px, transparent 1px);
      background-size: 40px 40px;
      pointer-events: none;
      z-index: 0;
    }

    .container {
      position: relative;
      z-index: 1;
      max-width: 1100px;
      margin: 0 auto;
      padding: 2rem 1.5rem 4rem;
    }

    .header {
      border-left: 3px solid var(--accent);
      padding-left: 1.25rem;
      margin-bottom: 2.5rem;
      animation: fadeIn 0.6s ease;
    }

    .header-label {
      font-family: var(--mono);
      font-size: 0.7rem;
      color: var(--accent2);
      letter-spacing: 0.15em;
      text-transform: uppercase;
      margin-bottom: 0.4rem;
    }

    .header h1 {
      font-size: 1.6rem;
      font-weight: 600;
      color: var(--text);
      line-height: 1.2;
      margin-bottom: 0.4rem;
    }

    .header p {
      font-size: 0.85rem;
      color: var(--text2);
      font-weight: 300;
    }

    .mode-toggle {
      display: flex;
      gap: 0;
      margin-bottom: 2rem;
      border: 1px solid var(--border);
      border-radius: 6px;
      overflow: hidden;
      width: fit-content;
      animation: fadeIn 0.7s ease;
    }

    .mode-btn {
      padding: 0.5rem 1.2rem;
      font-family: var(--mono);
      font-size: 0.75rem;
      letter-spacing: 0.05em;
      cursor: pointer;
      border: none;
      transition: all 0.2s;
      color: var(--text2);
      background: var(--panel);
    }

    .mode-btn.active {
      background: var(--accent);
      color: #ffffff;
    }

    .mode-hint {
      font-family: var(--mono);
      font-size: 0.72rem;
      color: var(--text3);
      margin-left: 1rem;
      align-self: center;
    }

    .inputs-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      margin-bottom: 1.5rem;
      animation: fadeIn 0.8s ease;
    }

    @media (max-width: 600px) {
      .inputs-grid {
        grid-template-columns: 1fr;
      }
    }

    .input-card {
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1rem 1.2rem;
      transition: border-color 0.2s;
    }

    .input-card:hover {
      border-color: var(--accent);
    }

    .input-card.warning {
      border-color: var(--orange);
    }

    .input-card.ok {
      border-color: var(--green);
    }

    .input-label {
      font-family: var(--mono);
      font-size: 0.7rem;
      color: var(--accent2);
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-bottom: 0.2rem;
    }

    .input-desc {
      font-size: 0.78rem;
      color: var(--text2);
      margin-bottom: 0.7rem;
      line-height: 1.4;
    }

    .input-row {
      display: flex;
      align-items: center;
      gap: 0.8rem;
    }

    input[type=range] {
      -webkit-appearance: none;
      flex: 1;
      height: 4px;
      border-radius: 2px;
      background: var(--border);
      outline: none;
      cursor: pointer;
    }

    input[type=range]::-webkit-slider-thumb {
      -webkit-appearance: none;
      width: 14px;
      height: 14px;
      border-radius: 50%;
      background: var(--accent);
      cursor: pointer;
      transition: background 0.2s;
    }

    input[type=range]:hover::-webkit-slider-thumb {
      background: var(--accent2);
    }

    input[type=number] {
      width: 110px;
      padding: 0.3rem 0.5rem;
      background: var(--panel2);
      border: 1px solid var(--border);
      border-radius: 4px;
      color: var(--text);
      font-family: var(--mono);
      font-size: 0.85rem;
      text-align: right;
      outline: none;
      transition: border-color 0.2s;
    }

    input[type=number]:focus {
      border-color: var(--accent);
    }

    .input-unit {
      font-family: var(--mono);
      font-size: 0.7rem;
      color: var(--text3);
      min-width: 60px;
    }

    .range-hint {
      font-family: var(--mono);
      font-size: 0.65rem;
      color: var(--text3);
      margin-top: 0.4rem;
      display: flex;
      justify-content: space-between;
    }

    .plausibility-warn {
      font-family: var(--mono);
      font-size: 0.68rem;
      color: var(--orange);
      margin-top: 0.35rem;
      display: none;
    }

    .plausibility-warn.show {
      display: block;
    }

    .cd-display {
      font-family: var(--mono);
      font-size: 0.82rem;
      color: var(--text);
      min-width: 90px;
      text-align: right;
    }

    .run-btn {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.75rem 2rem;
      background: var(--accent);
      border: none;
      border-radius: 6px;
      color: #ffffff;
      font-family: var(--mono);
      font-size: 0.85rem;
      font-weight: 500;
      letter-spacing: 0.05em;
      cursor: pointer;
      transition: all 0.2s;
      margin-bottom: 2rem;
    }

    .run-btn:hover {
      background: #2563eb;
      transform: translateY(-1px);
    }

    .run-btn:active {
      transform: translateY(0);
    }

    .run-btn .spinner {
      width: 14px;
      height: 14px;
      border: 2px solid rgba(255,255,255,0.3);
      border-top-color: #ffffff;
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
      display: none;
    }

    .run-btn.running .spinner {
      display: block;
    }

    .run-btn.running .btn-text {
      display: none;
    }

    .results {
      display: none;
      animation: slideUp 0.5s ease;
    }

    .results.show {
      display: block;
    }

    .results-header {
      font-family: var(--mono);
      font-size: 0.7rem;
      color: var(--text3);
      letter-spacing: 0.15em;
      text-transform: uppercase;
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .results-header::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    .routes-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
      margin-bottom: 2rem;
    }

    @media (max-width: 700px) {
      .routes-grid {
        grid-template-columns: 1fr;
      }
    }

    .route-card {
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1rem;
      position: relative;
      transition: all 0.3s;
    }

    .route-card.pareto {
      border-color: var(--accent);
      box-shadow: 0 0 20px rgba(59,130,246,0.1);
    }

    .route-card.top {
      border-color: var(--gold);
      box-shadow: 0 0 24px rgba(245,158,11,0.15);
    }

    .route-card.eliminated {
      opacity: 0.45;
      border-color: var(--border);
    }

    .route-badge {
      position: absolute;
      top: -8px;
      right: 10px;
      font-family: var(--mono);
      font-size: 0.6rem;
      padding: 0.15rem 0.5rem;
      border-radius: 3px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      font-weight: 600;
    }

    .badge-top {
      background: var(--gold);
      color: #0a0e14;
    }

    .badge-pareto {
      background: var(--accent);
      color: #ffffff;
    }

    .badge-out {
      background: var(--text3);
      color: var(--bg);
    }

    .route-name {
      font-family: var(--mono);
      font-size: 0.72rem;
      color: var(--accent2);
      letter-spacing: 0.08em;
      margin-bottom: 0.2rem;
    }

    .route-desc {
      font-size: 0.78rem;
      color: var(--text2);
      margin-bottom: 0.8rem;
      line-height: 1.4;
    }

    .prob-display {
      font-family: var(--mono);
      font-size: 1.8rem;
      font-weight: 600;
      margin-bottom: 0.15rem;
      line-height: 1;
    }

