// ── MODE TOGGLE ───────────────────────────────────────────────────────────
function setMode(m) {
  mode = m;
  document.getElementById('btn-slider').classList.toggle('active', m === 'slider');
  document.getElementById('btn-text').classList.toggle('active', m === 'text');
  document.getElementById('mode-hint').textContent =
    m === 'slider' ? '— drag to explore the parameter space'
                   : '— enter your measured values directly';
  // Show/hide elements
  ['mob','cd','dom','def','mono'].forEach(p => {
    const sl = document.getElementById('sl-'+p);
    const tx = document.getElementById('tx-'+p);
    if (m === 'slider') { sl.style.display=''; tx.style.display='none'; }
    else { sl.style.display='none'; tx.style.display=''; }
  });
  updateModeRecommendation();
}

function updateModeRecommendation() {
  const rec = document.getElementById('mode-rec');
  if (mode === 'slider') {
    rec.innerHTML = 'Currently in <strong>Explore</strong> mode — good for sensitivity analysis. Switch to <strong>Precise</strong> when you have Hall bar measurements to enter directly.';
  } else {
    rec.innerHTML = 'Currently in <strong>Precise</strong> mode — enter your measured values. Ensure carrier density reflects Raman strain-decomposed value (see Experiment 3).';
  }
}

function syncInput(param, val) {
  val = parseFloat(val);
  params[param] = val;
  document.getElementById('tx-'+param).value = val;
  checkPlausibility(param, val);
  updateCardState(param, val);
}

function syncSlider(param, val) {
  val = parseFloat(val);
  params[param] = val;
  const sl = document.getElementById('sl-'+param);
  if (sl) sl.value = val;
  checkPlausibility(param, val);
  updateCardState(param, val);
}

function checkPlausibility(param, val) {
  const warnEl = document.getElementById('warn-'+param);
  if (!warnEl) return;
  let warn = false;
  if (WARN_ABOVE[param] && val > WARN_ABOVE[param]) warn = true;
  if (WARN_BELOW[param] && val < WARN_BELOW[param]) warn = true;
  warnEl.classList.toggle('show', warn);
}

function updateCardState(param, val) {
  const card = document.getElementById('card-'+param);
  if (!card) return;
  const thresh = THRESH[param];
  let passes;
  if (param === 'cd' || param === 'def') passes = val < thresh;
  else passes = val > thresh;
  card.classList.toggle('ok', passes);
  card.classList.toggle('warning', !passes);
}

// ── MONTE CARLO ───────────────────────────────────────────────────────────
function randn() {
  // Box-Muller
  let u = 0, v = 0;
  while(u === 0) u = Math.random();
  while(v === 0) v = Math.random();
  return Math.sqrt(-2*Math.log(u)) * Math.cos(2*Math.PI*v);
}

function lognormalSample(mean, sdLog) {
  const muLog = Math.log(mean) - 0.5*sdLog*sdLog;
  return Math.exp(muLog + sdLog * randn());
}

// Compute pass probability for a given route + user measurement as updated prior mean
function computePassProb(route, userMeasurements, N=50000) {
  // We shift the prior mean toward the user measurement (likelihood update, simplified)
  // Weight: user measurement gets 60% weight, prior 40%
  const w = 0.6;
  const prior = route.prior;

  let passes = { mob:0, cd:0, dom:0, def:0, mono:0, all:0 };
  let joint = 0;

  for (let i = 0; i < N; i++) {
    // Updated means (Bayesian-inspired blend)
    const mobMean = prior.mob.mean * (1-w) + userMeasurements.mob * w;
    const cdMean  = prior.cd.mean  * (1-w) + userMeasurements.cd  * w;
    const domMean = prior.dom.mean * (1-w) + userMeasurements.dom * w;
    const defMean = prior.def.mean * (1-w) + userMeasurements.def * w;
    const monoMean= prior.mono.mean * (1-w) + userMeasurements.mono * w;

    // Correlated samples (simplified: apply correlation between mob and dom)
    const z1 = randn(), z2 = randn(), z3 = randn(), z4 = randn(), z5 = randn();
    const rho_mob_dom = 0.7;
    const z_dom = rho_mob_dom * z1 + Math.sqrt(1 - rho_mob_dom**2) * z2;
    const rho_def_cd = 0.3;
    const z_cd = rho_def_cd * z4 + Math.sqrt(1 - rho_def_cd**2) * z3;

    const mob  = Math.exp(Math.log(mobMean) - 0.5*prior.mob.sd**2 + prior.mob.sd * z1);
    const dom  = Math.exp(Math.log(Math.max(domMean,0.01)) - 0.5*prior.dom.sd**2 + prior.dom.sd * z_dom);
    const def  = Math.exp(Math.log(defMean) - 0.5*0.5**2 + 0.5 * z4);
    const cd   = Math.exp(Math.log(cdMean)  - 0.5*prior.cd.sd**2  + prior.cd.sd  * z_cd);
    const mono = Math.min(100, Math.max(0, monoMean + prior.mono.sd * z5));

    const pMob  = mob  > THRESH.mob  ? 1 : 0;
    const pDom  = dom  > THRESH.dom  ? 1 : 0;
    const pDef  = def  < THRESH.def  ? 1 : 0;
    const pCd   = cd   < THRESH.cd   ? 1 : 0;
    const pMono = mono > THRESH.mono ? 1 : 0;

    passes.mob  += pMob;
    passes.dom  += pDom;
    passes.def  += pDef;
    passes.cd   += pCd;
    passes.mono += pMono;
    passes.all  += pMob * pDom * pDef * pCd * pMono;
  }

  return {
    mob:  passes.mob  / N * 100,
    dom:  passes.dom  / N * 100,
    def:  passes.def  / N * 100,
    cd:   passes.cd   / N * 100,
    mono: passes.mono / N * 100,
    all:  passes.all  / N * 100
  };
}

// ── RUN SIMULATION ────────────────────────────────────────────────────────
function runSimulation() {
  const btn = document.getElementById('run-btn');
  btn.classList.add('running');

  setTimeout(() => {
    const userMeas = {
      mob:  params.mob,
      cd:   params.cd,
      dom:  params.dom,
      def:  params.def,
      mono: params.mono
    };

    // Compute for all routes
    const results = ROUTES.map(r => ({
      ...r,
      result: computePassProb(r, userMeas, 40000)
    }));

    // Sort by P(all)
    results.sort((a,b) => b.result.all - a.result.all);

    // Find binding constraint per route
    results.forEach(r => {
      const res = r.result;
      const margs = [
        { key:'mob', val:res.mob, dir:'high' },
        { key:'dom', val:res.dom, dir:'high' },
        { key:'def', val:res.def, dir:'high' },
        { key:'cd',  val:res.cd,  dir:'high' },
        { key:'mono',val:res.mono,dir:'high' }
      ];
      margs.sort((a,b) => a.val - b.val);
      r.binding = margs[0].key;
    });

    renderResults(results);

    btn.classList.remove('running');
    document.getElementById('results').classList.add('show');
    document.getElementById('results').scrollIntoView({ behavior:'smooth', block:'start' });
  }, 400);
}

// ── RENDER ────────────────────────────────────────────────────────────────
const PARAM_LABELS = { mob:'Mobility', dom:'Domain', def:'Defect', cd:'Carrier n', mono:'Monolayer' };
const BINDING_CLASSES = { mob:'binding-mob', cd:'binding-cd', dom:'binding-dom', def:'binding-def', mono:'binding-mono' };
const BINDING_LABELS = { mob:'Mobility binding', cd:'Carrier density binding', dom:'Domain size binding', def:'Defect density binding', mono:'Monolayer coverage binding' };

function probColor(p) {
  if (p >= 40) return '#10b981';
  if (p >= 25) return '#3b82f6';
  if (p >= 10) return '#f59e0b';
  return '#ef4444';
}

function renderResults(results) {
  const grid = document.getElementById('routes-grid');
  grid.innerHTML = '';

  results.forEach((r, idx) => {
    const p = r.result.all;
    const isTop = idx === 0;
    const isPareto = ['F','I','J'].includes(r.id) && p >= 10;
    const isOut = p < 5;

    let badge = '';
    if (isTop) badge = `<div class="route-badge badge-top">★ Top Route</div>`;
    else if (isPareto) badge = `<div class="route-badge badge-pareto">Pareto</div>`;
    else if (isOut) badge = `<div class="route-badge badge-out">Not viable</div>`;

    const marginals = ['mob','dom','def','cd','mono'].map(k => {
      const v = r.result[k];
      const col = v > 70 ? '#10b981' : v > 40 ? '#f59e0b' : '#ef4444';
      return `<div class="marginal-cell">
        <div class="marginal-label">${PARAM_LABELS[k].substring(0,4)}</div>
        <div class="marginal-val" style="color:${col}">${v.toFixed(0)}%</div>
      </div>`;
    }).join('');

    const card = document.createElement('div');
    card.className = `route-card ${isTop?'top':isPareto?'pareto':isOut?'eliminated':''}`;
    card.innerHTML = `
      ${badge}
      <div class="route-name">${r.name} · ${r.id}</div>
      <div class="route-desc">${r.desc}</div>
      <div class="prob-display" style="color:${probColor(p)}">${p.toFixed(1)}%</div>
      <div class="prob-label">P(all 5 criteria)</div>
      <div class="prob-bar">
        <div class="prob-bar-fill" style="width:${Math.min(p,100)}%;background:${probColor(p)}"></div>
      </div>
      <div>
        <span class="binding ${BINDING_CLASSES[r.binding]}">${BINDING_LABELS[r.binding]}</span>
      </div>
      <div class="marginals">${marginals}</div>
    `;
    grid.appendChild(card);
  });

  // Comparison section
  const compRows = document.getElementById('comparison-rows');
  compRows.innerHTML = '';
  ['F','I','J'].forEach(rid => {
    const r = results.find(x => x.id === rid);
    if (!r) return;
    const base = BASELINE[rid];
    const user = r.result.all;
    const delta = user - base;
    const deltaStr = delta >= 0 ? `+${delta.toFixed(1)}pp` : `${delta.toFixed(1)}pp`;
    const deltaCol = delta >= 0 ? '#10b981' : '#ef4444';

    const row = document.createElement('div');
    row.className = 'comp-row';
    row.innerHTML = `
      <div class="comp-route">${rid} · ${r.desc.split('→')[0].trim()}</div>
      <div class="comp-bars">
        <div class="comp-bar-row">
          <div class="comp-bar-label">Baseline</div>
          <div class="comp-bar-track">
            <div class="comp-bar-base" style="width:${base}%;background:var(--accent)"></div>
          </div>
          <div class="comp-val" style="color:var(--text2)">${base.toFixed(1)}%</div>
        </div>
        <div class="comp-bar-row">
          <div class="comp-bar-label">Your data</div>
          <div class="comp-bar-track">
            <div class="comp-bar-user" style="width:${Math.min(user,100)}%;background:var(--accent2)"></div>
          </div>
          <div class="comp-val" style="color:var(--accent2)">${user.toFixed(1)}% <span style="color:${deltaCol};font-size:0.6rem">${deltaStr}</span></div>
        </div>
      </div>
    `;
    compRows.appendChild(row);
  });

  // Diagnosis
  const top = results[0];
  const topP = top.result.all;
  const binding = top.binding;
  const crossoverMob = 3500 + Math.random() * 1000; // 3500-4500

  let diag = '';
  const mobVal = params.mob;
  const cdVal = params.cd;

  if (topP >= 40) {
    diag = `Your inputs place <strong>${top.name} (${top.id})</strong> as the leading route at <strong>${topP.toFixed(1)}%</strong> joint pass probability. `;
  } else if (topP >= 20) {
    diag = `Your inputs produce a viable but constrained result. <strong>${top.name}</strong> leads at <strong>${topP.toFixed(1)}%</strong>. `;
  } else {
    diag = `Your inputs produce low joint pass probabilities across all routes. <strong>${top.name}</strong> leads at only <strong>${topP.toFixed(1)}%</strong>. `;
  }

  const bindingAdvice = {
    mob: `The binding constraint is <strong>carrier mobility</strong>. At your entered value of ${mobVal.toLocaleString()} cm²/V·s, ` +
         (mobVal < 3500 ? `you are below the Route F/I crossover threshold of 3,500--4,500 cm²/V·s. Prioritise H-plasma treatment optimisation and Ni catalyst reduction.`
                        : mobVal < 4500 ? `you are within the Route F/I crossover window. Small mobility gains will shift the leading route.`
                        : `you are above the crossover threshold — Route F architectural advantages are now fully accessible.`),
    cd: `The binding constraint is <strong>carrier density</strong>. Residual doping at ${cdVal.toExponential(1)} cm⁻² exceeds the Pauli blocking threshold. ` +
        (cdVal > 1e12 ? `H-plasma treatment and substrate engineering are required. Confirm Raman measurements use strain-decomposition (Experiment 3).`
                      : `Consider whether transfer-induced charge traps are the primary source — hBN encapsulation reduces this penalty by ~4×.`),
    dom: `The binding constraint is <strong>domain size</strong>. This is a substrate physics wall if you are working with UNCD or polycrystalline substrates. ` +
         `For CVD routes, domain size is process-improvable through nucleation density reduction and longer growth times.`,
    def: `The binding constraint is <strong>defect density</strong>. Elevated I_D/I_G suggests point defects or grain boundary scattering. ` +
         `For CVD routes this is typically reducible with temperature and atmosphere optimisation. For in-place graphitization, Ni residual incorporation may be the source.`,
    mono: `The binding constraint is <strong>monolayer coverage</strong>. Bilayer island formation reduces average optical modulation depth. ` +
          `This is typically addressable through growth parameter tuning — lower carbon precursor partial pressure and longer annealing.`
  };

  diag += bindingAdvice[binding] || '';

  if (mobVal >= 3500 && mobVal <= 4500) {
    diag += ` <strong>Note:</strong> Your mobility value falls within the Route F/I crossover window (3,500--4,500 cm²/V·s). Results are sensitive to mobility precision here — switch to Precise mode and enter your measured Hall value for the most accurate ranking.`;
  }

  document.getElementById('diagnosis-text').innerHTML = diag;
}

// ── INIT ──────────────────────────────────────────────────────────────────
setMode('slider');
// Initialise card states
Object.keys(params).forEach(p => updateCardState(p, params[p]));
</script>

